# Copy to .env for local development. Every secret below accepts either a literal value (local)
# or a Secret Manager resource name (`projects/<p>/secrets/<s>/versions/latest`) in production,
# so no secret material needs to reach the Cloud Run environment.

# --- Google Cloud ---
SFB_GCP_PROJECT=my-project
SFB_GCP_REGION=europe-west2
SFB_TASKS_QUEUE=sir-fix-a-bot
# Set by Terraform in production; only needed locally if you exercise the enqueue path.
SFB_WORKER_URL=
SFB_TASKS_INVOKER_SA=

# --- Wiz ---
# Region-specific GraphQL endpoint for your tenant.
SFB_WIZ_API_URL=https://api.eu17.app.wiz.io/graphql
# Service account of type "Custom Integration - GraphQL" with the read:vulnerabilities scope.
SFB_WIZ_CLIENT_ID=
SFB_WIZ_CLIENT_SECRET=
# Shared secret the Wiz automation rule sends in the x-sfb-token header.
SFB_WIZ_WEBHOOK_SECRET=
SFB_WIZ_MIN_SEVERITY=HIGH

# --- Notion ---
# Internal integration secret (ntn_...). The hosted Notion MCP server is OAuth-browser-only and
# unusable headless, so we self-host @notionhq/notion-mcp-server over stdio with this token.
# Remember to share the CMDB page with the integration, or lookups return nothing.
SFB_NOTION_TOKEN=ntn_
SFB_NOTION_CMDB_DATABASE_ID=

# CMDB column names — Notion property names are free text and differ per workspace.
SFB_NOTION_PROP_SERVICE=Service Name
SFB_NOTION_PROP_REPO=GitHub Repo
SFB_NOTION_PROP_OWNER=Owner
SFB_NOTION_PROP_TEAM=Team
SFB_NOTION_PROP_BRANCH=Default Branch
SFB_NOTION_PROP_DOCKERFILE=Dockerfile Path

# --- GitHub ---
# A GitHub App, not a PAT: tokens are scoped to a single repository installation and expire
# within the hour. Needs contents:write and pull_requests:write.
SFB_GITHUB_APP_ID=
SFB_GITHUB_APP_PRIVATE_KEY=
SFB_GITHUB_LABEL=sir-fix-a-bot

# --- Anthropic ---
SFB_ANTHROPIC_API_KEY=
SFB_AGENT_MODEL=claude-opus-4-8
# xhigh is the recommended effort for coding and agentic work on Opus 4.8.
SFB_AGENT_EFFORT=xhigh
SFB_AGENT_TIMEOUT_S=900

# --- Behaviour ---
SFB_REPAIR_ATTEMPTS=1
SFB_DRY_RUN=false
